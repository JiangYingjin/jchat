{
  "apps": [
    {
      "name": "jchat",
      "cwd": "/www/jchat",
      "script": "server.js",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true,
      "max_memory_restart": "1G",
      "env": {
        "PORT": "8037"
      },
      "time": true,
      "merge_logs": true
    }
  ]
}

